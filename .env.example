# Azure Voice Live API — WebRTC 샘플 설정
# 이 파일을 `.env`로 복사한 뒤 값을 채우세요. `.env`는 절대 커밋하지 마세요.

# Foundry / Azure AI 리소스 엔드포인트.
#   예: my-foundry-resource
#   예: https://my-foundry-resource.cognitiveservices.azure.com/
AZURE_VOICELIVE_ENDPOINT=https://<리소스-이름>.cognitiveservices.azure.com/

# 인증 — API 키 사용 (로컬 랩에서 가장 간단). 서버에만 보관되며 브라우저로는 전달되지 않습니다.
AZURE_VOICELIVE_API_KEY=<your-api-key>

# WebRTC는 프리뷰 API 버전이 필요합니다.
AZURE_VOICELIVE_API_VERSION=2026-06-01-preview

# 에이전트를 구동하는 생성 모델. 전체 목록은 공식 문서를 참고하세요.
AZURE_VOICELIVE_MODEL=gpt-realtime-1.5

# 출력 보이스.
AZURE_VOICELIVE_VOICE=alloy

# 로컬 웹 서버 포트.
PORT=8888

# 인덱싱된 Azure AI Search.
AZURE_AI_SEARCH_ENDPOINT=https://<검색-서비스>.search.windows.net
AZURE_AI_SEARCH_ADMIN_KEY=<your-search-admin-key>
AZURE_AI_SEARCH_INDEX=<your-index-name>
# LangChain AzureSearch 기본 필드명. 인덱스가 다르면 맞춰주세요.
AZURE_AI_SEARCH_CONTENT_FIELD=<your-content-field>
AZURE_AI_SEARCH_VECTOR_FIELD=<your-vector-field>
AZURE_AI_SEARCH_TOP_K=3

# Azure OpenAI 임베딩 (쿼리 벡터화). 인덱싱에 쓴 임베딩 모델과 동일해야 합니다.
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://<리소스-이름>.openai.azure.com
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=<embedding-deployment>
AZURE_OPENAI_EMBEDDING_API_KEY=<your-openai-key>
